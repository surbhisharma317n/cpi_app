-- ===========================
-- STATE MASTER
-- ===========================
CREATE TABLE state_master (
    state_id INT PRIMARY KEY,
    nss_state_code VARCHAR(20) UNIQUE,
    nss_state_name VARCHAR(100),
    lgd_state_code INT UNIQUE,
    lgd_state_name VARCHAR(100),
    state_name VARCHAR(100) NOT NULL,
    state_ut VARCHAR(20),
    is_active BOOLEAN NOT NULL DEFAULT TRUE CHECK (is_active IN (TRUE, FALSE)),
    created_by VARCHAR(100),
    updated_by VARCHAR(100),
    created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- ===========================
-- DISTRICT MASTER
-- ===========================
CREATE TABLE district_master (
    district_id INT PRIMARY KEY,
    nss_district_code VARCHAR(20) UNIQUE,
    nss_district_name VARCHAR(100),
    lgd_district_code INT UNIQUE,
    lgd_district_name VARCHAR(100),
    district_name VARCHAR(100),
    state_id INT NOT NULL REFERENCES state_master(state_id) ON DELETE CASCADE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE CHECK (is_active IN (TRUE, FALSE)),
    created_by VARCHAR(100),
    updated_by VARCHAR(100),
    created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- ===========================
-- SUBDISTRICT MASTER
-- ===========================
CREATE TABLE subdistrict_master (
    subdistrict_id INT PRIMARY KEY,
    nss_subdistrict_code VARCHAR(20) UNIQUE,
    nss_subdistrict_name VARCHAR(100),
    lgd_subdistrict_code INT UNIQUE,
    lgd_subdistrict_name VARCHAR(100),
    subdistrict_name VARCHAR(100),
    district_id INT NOT NULL REFERENCES district_master(district_id) ON DELETE CASCADE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE CHECK (is_active IN (TRUE, FALSE)),
    created_by VARCHAR(100),
    updated_by VARCHAR(100),
    created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- ===========================
-- VILLAGE MASTER
-- ===========================
CREATE TABLE vill_master (
    vill_id INT PRIMARY KEY,
    nss_vill_code VARCHAR(20) UNIQUE,
    nss_vill_name VARCHAR(100),
    lgd_vill_code INT UNIQUE,
    lgd_vill_name VARCHAR(100),
    vill_name VARCHAR(100),
    subdistrict_id INT NOT NULL REFERENCES subdistrict_master(subdistrict_id) ON DELETE CASCADE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE CHECK (is_active IN (TRUE, FALSE)),
    created_by VARCHAR(100),
    updated_by VARCHAR(100),
    created_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- ===========================
-- TOWN MASTER
-- ===========================
-- CREATE TABLE town_master (
--     town_id INT PRIMARY KEY,
--     nss_town_code VARCHAR(20) UNIQUE,
--     nss_town_name VARCHAR(100),
--     lgd_town_code INT UNIQUE,
--     lgd_town_name VARCHAR(100),
       
